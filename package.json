{
  "name": "@tanaabased/prepare-release-action",
  "version": "1.1.1",
  "description": "An action that can automate release steps and sync them back to the releasing repo.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "contributors": [
    "Mike Pirog @pirog"
  ],
  "license": "MIT",
  "repository": "https://github.com/tanaabased/prepare-release-action",
  "bugs": "https://github.com/tanaabased/prepare-release-action/issues",
  "homepage": "https://github.com/tanaabased/prepare-release-action",
  "keywords": [
    "Github Actions"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.4",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "6",
    "jsonfile": "^6.1.0",
    "lodash.set": "^4.3.2",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.5.3"
  },
  "scripts": {
    "test": "c8 --all --include \"utils/*.js\" --reporter=text --check-coverage --per-file --lines 80 mocha \"test/**/*.spec.js\"",
    "lint": "eslint . --format json",
    "format:check": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown",
    "build": "bun build ./prepare-release.js --target=bun --format=esm --sourcemap=linked --outdir dist --entry-naming index.js",
    "prepare": "bun run build"
  }
}
